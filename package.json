{
  "name": "@raptorsolutions/webhook-client",
  "version": "1.0.0",
  "description": "Client para registrar eventos webhook hacia el gestor Raptor",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
