{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "ignoreDeprecations": "6.0",

    "types": ["node", "vitest/globals"]
  },

  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["dist", "node_modules"]
}
